# Round 41 bootstrap overlay — sets adapter scope for verify-round.sh proof checks.
#
# verify-round.sh r41-3 tests the direct transparent proxy path:
#   curl http://127.0.0.1:8090/t/v1/chat/completions -H 'Authorization: Bearer openai_prod'
#
# The proxy must be allowed to fetch openai_prod from subumbra-keys for this check
# to succeed. Without this overlay, clean-run bootstraps with PROXY_ALLOWED_KEYS=""
# (empty from .env.bootstrap.example default), causing subumbra-keys to return 403
# on every proxy key fetch.
PROXY_ALLOWED_KEYS=openai_prod
