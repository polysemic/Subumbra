#!/usr/bin/env python3
from __future__ import annotations

import argparse
import hashlib
import json
import os
import subprocess
import sys
import urllib.error
import urllib.parse
import urllib.request
from email import policy
from email.parser import BytesParser
from pathlib import Path
from typing import Any


REPO_ROOT = Path(__file__).resolve().parent.parent
DEFAULT_INTEGRITY_FILE = Path(os.environ.get("DATA_DIR", "/app/data")) / "system-integrity.json"
DEFAULT_KEYS_CONTAINER = "subumbra-keys"
DEFAULT_CONTAINER_INTEGRITY_PATH = "/app/data/system-integrity.json"


def die(message: str, exit_code: int = 1) -> "NoReturn":
    print(message, file=sys.stderr)
    raise SystemExit(exit_code)


def load_dotenv(path: Path) -> dict[str, str]:
    values: dict[str, str] = {}
    if not path.exists():
        return values
    for raw_line in path.read_text(encoding="utf-8", errors="replace").splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, _, value = line.partition("=")
        key = key.strip()
        value = value.strip()
        if len(value) >= 2 and value[0] == value[-1] and value[0] in {"'", '"'}:
            value = value[1:-1]
        values[key] = value
    return values


def _infer_worker_name_from_url(url: str) -> str:
    """Derive worker script name from a *.workers.dev URL (best-effort)."""
    try:
        host = (urllib.parse.urlparse(url.strip()).hostname or "").strip().lower()
    except Exception:
        return ""
    labels = host.split(".")
    if len(labels) >= 3 and labels[-2] == "workers" and labels[-1] == "dev":
        return labels[0]
    return ""


def resolve_credentials() -> dict[str, str]:
    repo_env = load_dotenv(REPO_ROOT / ".env")
    resolved: dict[str, str] = {}
    for name in ("CF_API_TOKEN", "CF_ACCOUNT_ID"):
        value = os.environ.get(name, "").strip() or repo_env.get(name, "").strip()
        if not value:
            die(f"missing required credential: {name}")
        resolved[name] = value
    worker_name = (
        os.environ.get("CF_WORKER_NAME", "").strip()
        or repo_env.get("CF_WORKER_NAME", "").strip()
    )
    if not worker_name:
        worker_url = (
            os.environ.get("CF_WORKER_URL", "").strip()
            or repo_env.get("CF_WORKER_URL", "").strip()
        )
        worker_name = _infer_worker_name_from_url(worker_url)
    if not worker_name:
        die(
            "missing required credential: CF_WORKER_NAME\n"
            "  Set CF_WORKER_NAME in .env, or set CF_WORKER_URL to a *.workers.dev URL "
            "and CF_WORKER_NAME will be inferred."
        )
    resolved["CF_WORKER_NAME"] = worker_name
    return resolved


def cf_api_json(path: str, creds: dict[str, str]) -> Any:
    request = urllib.request.Request(
        f"https://api.cloudflare.com/client/v4{path}",
        headers={
            "Authorization": f"Bearer {creds['CF_API_TOKEN']}",
            "Content-Type": "application/json",
        },
    )
    try:
        with urllib.request.urlopen(request, timeout=30) as response:
            return json.loads(response.read().decode("utf-8"))
    except urllib.error.HTTPError as exc:
        die(f"Cloudflare API request failed with HTTP {exc.code}")
    except urllib.error.URLError as exc:
        die(f"Cloudflare API request failed: {exc.reason}")


def cf_api_bytes(path: str, creds: dict[str, str]) -> tuple[bytes, str]:
    request = urllib.request.Request(
        f"https://api.cloudflare.com/client/v4{path}",
        headers={"Authorization": f"Bearer {creds['CF_API_TOKEN']}"},
    )
    try:
        with urllib.request.urlopen(request, timeout=30) as response:
            return response.read(), response.headers.get("Content-Type", "")
    except urllib.error.HTTPError as exc:
        die(f"Cloudflare content fetch failed with HTTP {exc.code}")
    except urllib.error.URLError as exc:
        die(f"Cloudflare content fetch failed: {exc.reason}")


def latest_version_id(creds: dict[str, str]) -> str:
    payload = cf_api_json(
        f"/accounts/{creds['CF_ACCOUNT_ID']}/workers/scripts/{creds['CF_WORKER_NAME']}/deployments",
        creds,
    )
    deployments = payload.get("result", payload).get("deployments")
    if not isinstance(deployments, list) or not deployments:
        die("no live worker deployment found")
    latest = deployments[0]
    versions = latest.get("versions")
    if isinstance(versions, list) and versions:
        version_id = versions[0].get("version_id")
        if isinstance(version_id, str) and version_id:
            return version_id
    version_id = latest.get("version_id")
    if isinstance(version_id, str) and version_id:
        return version_id
    die("unable to resolve live worker version")


def extract_hash_bytes(body: bytes, content_type: str) -> bytes:
    if "multipart/form-data" not in content_type.lower():
        return body
    message = BytesParser(policy=policy.default).parsebytes(
        f"Content-Type: {content_type}\r\nMIME-Version: 1.0\r\n\r\n".encode("utf-8") + body
    )
    parts = list(message.iter_parts())
    if not parts:
        return body
    entrypoint = message.get("cf-entrypoint")
    if entrypoint:
        for part in parts:
            filename = part.get_filename()
            if filename == entrypoint:
                payload = part.get_payload(decode=True)
                if payload is not None:
                    return payload
    for part in parts:
        payload = part.get_payload(decode=True)
        if payload is not None:
            return payload
    return body


def live_worker_hash(creds: dict[str, str]) -> str:
    version_id = latest_version_id(creds)
    body, content_type = cf_api_bytes(
        f"/accounts/{creds['CF_ACCOUNT_ID']}/workers/scripts/{creds['CF_WORKER_NAME']}/content/v2?version={version_id}",
        creds,
    )
    return hashlib.sha256(extract_hash_bytes(body, content_type)).hexdigest()


def parse_integrity_payload(raw_text: str) -> dict[str, Any]:
    try:
        payload = json.loads(raw_text)
    except json.JSONDecodeError as exc:
        die(f"integrity artifact invalid JSON: {exc}")
    if not isinstance(payload, dict):
        die("integrity artifact must be a JSON object")
    expected_hash = payload.get("bundle_sha256")
    if not isinstance(expected_hash, str) or not expected_hash:
        die("integrity artifact missing bundle_sha256")
    return payload


def load_integrity(path: Path, keys_container: str, container_path: str) -> dict[str, Any]:
    if path.exists():
        return parse_integrity_payload(path.read_text(encoding="utf-8"))
    try:
        result = subprocess.run(
            ["docker", "exec", keys_container, "cat", container_path],
            capture_output=True,
            check=True,
            text=True,
        )
    except FileNotFoundError:
        die(
            "integrity artifact not found on host "
            f"({path}) and docker is unavailable for container fallback "
            f"({keys_container}:{container_path})"
        )
    except subprocess.CalledProcessError as exc:
        detail = exc.stderr.strip() or exc.stdout.strip() or f"exit {exc.returncode}"
        die(
            "integrity artifact not found on host "
            f"({path}) and container fallback failed "
            f"({keys_container}:{container_path}): {detail}"
        )
    return parse_integrity_payload(result.stdout)


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser()
    parser.add_argument("--integrity-file", default=str(DEFAULT_INTEGRITY_FILE))
    parser.add_argument("--keys-container", default=DEFAULT_KEYS_CONTAINER)
    parser.add_argument(
        "--container-integrity-path",
        default=DEFAULT_CONTAINER_INTEGRITY_PATH,
    )
    return parser.parse_args()


def main() -> None:
    args = parse_args()
    integrity = load_integrity(
        Path(args.integrity_file),
        args.keys_container,
        args.container_integrity_path,
    )
    creds = resolve_credentials()
    live_hash = live_worker_hash(creds)
    expected_hash = integrity["bundle_sha256"]
    if live_hash != expected_hash:
        die("integrity drift detected", exit_code=2)
    print("integrity verified")


if __name__ == "__main__":
    main()
