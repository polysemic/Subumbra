# Append these lines to LibreChat's root .env file.

ALLOW_EMAIL_LOGIN=true
ALLOW_REGISTRATION=true
# The promoted multi-provider librechat.yaml now uses literal key_id examples.
# Keep SUBUMBRA_KEY_ID only if you convert the active OpenAI entry back to
# env-substitution for your own setup.
SUBUMBRA_KEY_ID=openai_prod
