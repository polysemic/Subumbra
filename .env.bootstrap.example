# ─────────────────────────────────────────────────────────────────────────────
# .env.bootstrap.example — OPTIONAL automation/CI fallback
#
# For normal interactive use, you do NOT need this file:
#   docker compose --profile bootstrap run --rm -it bootstrap
#   (wizard prompts for all credentials; nothing is written to disk)
#
# For CI/headless automation only:
#   cp .env.bootstrap.example .env.bootstrap
#   # edit .env.bootstrap with real values
#   docker compose --profile bootstrap run --rm bootstrap
#   ./post-bootstrap.sh    # copies tokens to .env and shreds this file
#
# NEVER commit .env.bootstrap — .gitignore blocks it, but verify.
# ─────────────────────────────────────────────────────────────────────────────

# ── API keys to encrypt ───────────────────────────────────────────────────────
# These are collected interactively (wizard) or read from this file (CI/headless).
# Wizard mode: values exist in RAM only, never written to disk.
# CI mode: this file contains plaintext keys — shred immediately after bootstrap.

ANTHROPIC_KEY=<your_anthropic_key>
OPENAI_KEY=<your_openai_key>
GROQ_KEY=<your_groq_key>
DEEPSEEK_KEY=<your_deepseek_key>
CEREBRAS_API_KEY=<your_cerebras_api_key>
GEMINI_API_KEY=<your_gemini_api_key>
MISTRAL_API_KEY=<your_mistral_api_key>
OPENROUTER_API_KEY=<your_openrouter_api_key>
TOGETHER_AI_API_KEY=<your_together_ai_api_key>
XAI_API_KEY=<your_xai_api_key>
GITHUB_KEY=<your_github_token>
SLACK_KEY=<your_slack_bot_token>
SENDGRID_KEY=<your_sendgrid_key>

# Optional automation-mode key_id overrides.
# If omitted, bootstrap uses the same default suggestions as the wizard, such as
# anthropic_prod or github_prod. Set these only when you want automation mode to
# use custom key_ids such as anthropic_test or github_main.
ANTHROPIC_KEY_ID=
OPENAI_KEY_ID=
GROQ_KEY_ID=
DEEPSEEK_KEY_ID=
CEREBRAS_KEY_ID=
GEMINI_KEY_ID=
MISTRAL_KEY_ID=
OPENROUTER_KEY_ID=
TOGETHER_AI_KEY_ID=
XAI_KEY_ID=
GITHUB_KEY_ID=
SLACK_KEY_ID=
SENDGRID_KEY_ID=

# ── Cloudflare credentials (for wrangler deploy + secret push) ───────────────
# Create an API token at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Workers Scripts:Edit, Workers KV Storage:Edit
CF_API_TOKEN=REPLACE_ME
CF_ACCOUNT_ID=REPLACE_ME
CF_WORKER_NAME=subumbra-proxy

# Single bootstrap-time TTL applied to all adapter registry entries.
TOKEN_TTL_DAYS=90

# ── Adapter key scopes ────────────────────────────────────────────────────────
# Comma-separated key_id allowlists written into SUBUMBRA_ADAPTER_REGISTRY.
# These lists should contain the exact key_ids chosen during bootstrap.
# LiteLLM_ALLOWED_KEYS drives which records LiteLLM may fetch for subumbra:key_id
# model entries. PROXY_ALLOWED_KEYS drives sidecar access. PROBE_ALLOWED_KEYS
# drives subumbra-probe coverage.
# UI_ALLOWED_KEYS must remain empty; the UI is metadata-only and may list keys
# or read stats, but it must not be granted ciphertext fetch scope.
# ADAPTER_IDS is additive-only; built-ins remain provisioned automatically.
# Custom adapters use <NORMALIZED_ID>_ALLOWED_KEYS, where normalization is:
# uppercase + replace '-' with '_'. Example:
# ADAPTER_IDS=test-adapter
# TEST_ADAPTER_ALLOWED_KEYS=test_provider_prod
ADAPTER_IDS=
LITELLM_ALLOWED_KEYS=
PROXY_ALLOWED_KEYS=
PROBE_ALLOWED_KEYS=
UI_ALLOWED_KEYS=

# ── Headless server auth (optional) ──────────────────────────────────────────
# On servers without a browser (CI/CD, Citadel, Docker), wrangler cannot open
# an OAuth flow. Set this to your CF API token to bypass OAuth entirely.
# The bootstrap container sets CLOUDFLARE_API_TOKEN from CF_API_TOKEN above
# automatically — this entry is only needed when running wrangler outside Docker.
# CLOUDFLARE_API_TOKEN=REPLACE_ME
