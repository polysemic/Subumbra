# .env.bootstrap.example — automation bootstrap secrets (DELETE AFTER USE)
#
# Copy to `.env.bootstrap`, fill REPLACE_ME values, run `./bootstrap.sh`.
# On success the host wrapper shreds `.env.bootstrap` (except `--provision` repair).
#
# Interactive (TTY) path: omit this file and run `./bootstrap.sh`; secrets stay in RAM.
#
# For repeated automation testing without retyping secrets, operators often keep a
# **gitignored** local copy named `.env.bootstrap_bak` (see `.gitignore`). That file
# is never committed; sync its shape with this example when bootstrap env vars change.
#
# Manifest: `manifest.yaml` is gitignored. Copy from tracked templates first:
#   cp manifest.minimal.yaml manifest.yaml
#   # or: cp manifest.example.yaml manifest.yaml
#
# Cloudflare (required for automation bootstrap)
CF_API_TOKEN=REPLACE_ME
CF_ACCOUNT_ID=REPLACE_ME
CF_WORKER_NAME=subumbra-proxy

# Optional: Cloudflare Tunnel and Access runtime credentials
# These are collected by the interactive wizard if omitted here.
# If set here, bootstrap writes them to .env and shreds .env.bootstrap on success.
# Optional auto-provisioning inputs for Cloudflare Tunnel / DNS / Access
# CF_ZONE_ID=
# CF_TUNNEL_NAME=
# CF_TUNNEL_HOSTNAME=
# CF_ACCESS_APP_NAME=
# CF_SERVICE_TOKEN_NAME=
# TUNNEL_TOKEN=
# CF_ACCESS_CLIENT_ID=
# CF_ACCESS_CLIENT_SECRET=

# Optional bootstrap tuning
TOKEN_TTL_DAYS=365

# --- Provider secrets referenced by `secret_ref` in manifest.yaml ---
# Each line name must match the `secret_ref` value in your manifest exactly.
# The names below match the tracked `manifest.minimal.yaml`.
# Uncomment and fill only the providers you use.

OPENAI_KEY=REPLACE_ME
# ANTHROPIC_KEY=REPLACE_ME
# GEMINI_KEY=REPLACE_ME
# GROQ_KEY=REPLACE_ME
# MISTRAL_KEY=REPLACE_ME
# DEEPSEEK_KEY=REPLACE_ME
# OPENROUTER_KEY=REPLACE_ME
# TOGETHER_KEY=REPLACE_ME
# XAI_KEY=REPLACE_ME
# GITHUB_KEY=REPLACE_ME
# SLACK_KEY=REPLACE_ME
# SENDGRID_KEY=REPLACE_ME
