# ─────────────────────────────────────────────────────────────────────────────
# .env.bootstrap.example — OPTIONAL automation/CI bootstrap input
#
# For the interactive RAM-only path, you do NOT need this file:
#   docker compose --profile bootstrap run --rm -it bootstrap
#
# Use this file when:
# - you want repeatable app-owned adapter setup
# - you are provisioning custom app adapters such as LiteLLM or OpenWebUI
# - you are running headless / CI automation
#
# Automation path:
#   cp .env.bootstrap.example .env.bootstrap
#   # edit .env.bootstrap with real values
#   ./bootstrap.sh
#
# NEVER commit .env.bootstrap — .gitignore blocks it, but verify.
# ─────────────────────────────────────────────────────────────────────────────

# ── Provider API keys to encrypt ─────────────────────────────────────────────
# Values in this file are plaintext until bootstrap finishes. `./bootstrap.sh`
# shreds `.env.bootstrap` after a successful run.

ANTHROPIC_KEY=<your_anthropic_key>
OPENAI_KEY=<your_openai_key>
GROQ_KEY=<your_groq_key>
DEEPSEEK_KEY=<your_deepseek_key>
CEREBRAS_API_KEY=<your_cerebras_api_key>
GEMINI_API_KEY=<your_gemini_api_key>
MISTRAL_API_KEY=<your_mistral_api_key>
OPENROUTER_API_KEY=<your_openrouter_api_key>
TOGETHER_AI_API_KEY=<your_together_ai_api_key>
XAI_API_KEY=<your_xai_api_key>
GITHUB_KEY=<your_github_token>
SLACK_KEY=<your_slack_bot_token>
SENDGRID_KEY=<your_sendgrid_key>

# Optional automation-mode key_id overrides.
# Leave blank to use the default provider_prod suggestions.
ANTHROPIC_KEY_ID=
OPENAI_KEY_ID=
GROQ_KEY_ID=
DEEPSEEK_KEY_ID=
CEREBRAS_KEY_ID=
GEMINI_KEY_ID=
MISTRAL_KEY_ID=
OPENROUTER_KEY_ID=
TOGETHER_AI_KEY_ID=
XAI_KEY_ID=
GITHUB_KEY_ID=
SLACK_KEY_ID=
SENDGRID_KEY_ID=

# ── Cloudflare credentials ───────────────────────────────────────────────────
# Create an API token at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Workers Scripts:Edit, Workers KV Storage:Edit
CF_API_TOKEN=REPLACE_ME
CF_ACCOUNT_ID=REPLACE_ME
CF_WORKER_NAME=subumbra-proxy
TOKEN_TTL_DAYS=90

# ── Adapter scopes / app identities ──────────────────────────────────────────
# Built-ins remain provisioned automatically:
# - subumbra-proxy
# - subumbra-ui
# - subumbra-probe (only if PROBE_ALLOWED_KEYS is non-empty in automation mode)
#
# Custom app adapters are additive. Each adapter_id generates:
# - a SUBUMBRA_TOKEN_<NORMALIZED_ID> value in runtime.env / .env
# - an adapter entry in SUBUMBRA_ADAPTER_REGISTRY
#
# Normalization rule:
# - uppercase
# - replace '-' with '_'
#
# Example:
# ADAPTER_IDS=litellm,openwebui
# LITELLM_ALLOWED_KEYS=anthropic_prod,openai_prod
# OPENWEBUI_ALLOWED_KEYS=anthropic_prod,openai_prod
#
# These allowlists contain key_ids, not provider names.
ADAPTER_IDS=
PROXY_ALLOWED_KEYS=
PROBE_ALLOWED_KEYS=
UI_ALLOWED_KEYS=

# Example custom adapter allowlists (uncomment and edit for secure app-owned setup):
# LITELLM_ALLOWED_KEYS=anthropic_prod,openai_prod
# OPENWEBUI_ALLOWED_KEYS=anthropic_prod,openai_prod

# ── Optional app-owned .env imports (consumed by ./bootstrap.sh) ──────────────
# IMPORT_PATH_<n> must point to a host file. ./bootstrap.sh mounts it readonly
# into the bootstrap container and passes the in-container path automatically.
# IMPORT_APP_LABEL_<n> is required for each import and becomes part of the
# generated key_id format: <provider>_<app_label>_<ordinal>.
#
# Example:
# IMPORT_PATH_1=/opt/litellm/.env
# IMPORT_APP_LABEL_1=litellm
# IMPORT_PATH_2=/opt/openwebui/.env
# IMPORT_APP_LABEL_2=openwebui

# ── Headless server auth (optional) ──────────────────────────────────────────
# On servers without a browser (CI/CD, Citadel, Docker), wrangler cannot open
# an OAuth flow. Set this to your CF API token to bypass OAuth entirely.
# The bootstrap container sets CLOUDFLARE_API_TOKEN from CF_API_TOKEN above
# automatically — this entry is only needed when running wrangler outside Docker.
# CLOUDFLARE_API_TOKEN=REPLACE_ME
