# .env.bootstrap.example
#
# Copy to `.env.bootstrap`, fill in real secret values, and run:
#   ./bootstrap.sh
#
# This file is secret-only for the manifest bootstrap flow.
# Keep the durable routing and policy configuration in `subumbra.json`.

# Provider secrets referenced by subumbra.json `secret_ref` values.
ANTHROPIC_KEY=REPLACE_ME

# Cloudflare bootstrap credentials.
CF_API_TOKEN=REPLACE_ME
CF_ACCOUNT_ID=REPLACE_ME
CF_WORKER_NAME=subumbra-proxy

# Optional bootstrap settings.
TOKEN_TTL_DAYS=90
