{
  "keys": [
    {
      "key_id": "anthropic_prod",
      "provider": "anthropic",
      "secret_ref": "ANTHROPIC_KEY",
      "adapters": ["litellm", "bifrost", "librechat"],
      "unique_vault": false,
      "policy": {
        "key_id": "anthropic_prod",
        "policy_id": "anthropic-prod-minimal",
        "protocol": "http_rest",
        "capability_class": "llm",
        "source": "env",
        "target": {
          "host": "api.anthropic.com",
          "base_path": "/v1"
        },
        "auth": {
          "scheme": "header",
          "header_name": "x-api-key"
        },
        "allow": {
          "adapters": ["litellm", "bifrost", "librechat"],
          "methods": ["GET", "POST"],
          "path_prefixes": ["/v1/"],
          "content_types": ["application/json"],
          "max_body_bytes": 2097152
        },
        "velocity": {
          "breaker_failures": 2,
          "breaker_cooldown_seconds": 15
        }
      }
    },
    {
      "key_id": "openai_prod",
      "provider": "openai",
      "secret_ref": "OPENAI_KEY",
      "adapters": ["litellm", "anythingllm", "librechat", "openwebui"],
      "unique_vault": false,
      "policy": {
        "key_id": "openai_prod",
        "policy_id": "openai-prod-minimal",
        "protocol": "openai_compatible",
        "capability_class": "llm",
        "source": "env",
        "target": {
          "host": "api.openai.com",
          "base_path": "/v1"
        },
        "auth": {
          "scheme": "bearer"
        },
        "allow": {
          "adapters": ["litellm", "anythingllm", "librechat", "openwebui"],
          "methods": ["GET", "POST"],
          "path_prefixes": ["/v1/"],
          "content_types": ["application/json"],
          "max_body_bytes": 2097152
        },
        "velocity": {
          "adapter_rpm": 3
        }
      }
    }
  ]
}
