# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Subumbra core runtime environment template
#
# Usage:
#   cp .env.example .env
#   # Then run:
#   #   ./bootstrap.sh
#   # On success this runs `docker compose up -d --force-recreate` and prints an
#   # adapter / key_id summary (see also `./bootstrap.sh --upgrade` for image-only updates).
#   # bootstrap.sh fills in all generated runtime values, CF_WORKER_URL, and
#   # *_ALLOWED_KEYS automatically from the bootstrap output.
#   # Cloudflare Tunnel / CF Access runtime credentials can be provided via
#   # the interactive wizard or optional lines in .env.bootstrap.
#
# App-owned integrations such as standalone LiteLLM keep their own .env files
# outside this repo. See docs/standalone-litellm.md.
#
# NEVER commit .env — only .env.example is safe to commit.
# ─────────────────────────────────────────────────────────────────────────────

# ── Optional: Cloudflare Access service token ─────────────────────────────────
# Only needed if you put Cloudflare Access in front of the CF Worker.
# Leave blank if you are not using CF Access. `CF_ACCESS_CLIENT_SECRET` is a
# persistent runtime secret when enabled; `CF_ACCESS_CLIENT_ID` is the paired
# service-token identifier for that configuration.
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# ── Optional: UI auth state ───────────────────────────────────────────────────
# These are written by bootstrap when UI deployment is enabled. Do not store a
# plaintext UI password in .env; rotate with `./bootstrap.sh --update-ui-auth`.
UI_USERNAME=
UI_PASSWORD_HASH=
CF_ACCESS_PROTECTED=

# ── Optional: Cloudflare Tunnel token ────────────────────────────────────────
# Only needed if you use cloudflared to expose services. `TUNNEL_TOKEN` is a
# persistent runtime secret when enabled.
# Leave blank to skip.
TUNNEL_TOKEN=

# ── Optional: audit log row cap (default 10000) ───────────────────────────────
AUDIT_MAX_ROWS=10000

# ── Optional: SSH gate/poll timeout (default 30 seconds) ─────────────────────
# Used by subumbra-proxy and subumbra-agent when waiting through gate approval
# for SSH signing requests. Leave at 30 for backward-compatible behavior unless
# your gate policy timeouts require a higher ceiling.
SUBUMBRA_SIGN_TIMEOUT=30

# ── Generated by bootstrap.sh — do not edit manually ──────────────────────────
# Runtime values below are injected into each service container's environment (see docs/operator-guide.md section "SEC-4 — Container environment and process visibility").
# These are filled in automatically after a successful bootstrap run.
# They are listed here so you can see the full expected shape of .env.
SUBUMBRA_CONSUMER_REGISTRY=
SUBUMBRA_TOKEN_PROXY=
SUBUMBRA_TOKEN_UI=
SUBUMBRA_TOKEN_PROBE=
SUBUMBRA_HMAC_KEY=
# Optional: Worker script name (used by day-2 bootstrap commands; otherwise inferred from CF_WORKER_URL when possible).
CF_WORKER_NAME=
CF_WORKER_URL=
SUBUMBRA_JANUS_VAPID_PUBLIC_KEY=
PROBE_ALLOWED_KEYS=
UI_ALLOWED_KEYS=
DEPLOY_UI=
DEPLOY_SSH=
