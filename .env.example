# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Subumbra runtime environment template
#
# Usage:
#   cp .env.example .env
#   # Edit LITELLM_MASTER_KEY (generate: openssl rand -hex 32)
#   # Optionally set CF_ACCESS_CLIENT_ID / CF_ACCESS_CLIENT_SECRET
#   # Then run bootstrap:
#   #   docker compose --profile bootstrap run --rm -it bootstrap
#   # Then run:
#   #   ./post-bootstrap.sh
#   # post-bootstrap.sh fills in all FORGE_* values, CF_WORKER_URL, and
#   # *_ALLOWED_KEYS automatically from the bootstrap output.
#
# NEVER commit .env — only .env.example is safe to commit.
# ─────────────────────────────────────────────────────────────────────────────

# ── Set this before running post-bootstrap.sh ────────────────────────────────
# Generate with: openssl rand -hex 32
LITELLM_MASTER_KEY=change-me-use-openssl-rand-hex-32

# ── Optional: Cloudflare Access service token ─────────────────────────────────
# Only needed if you put Cloudflare Access in front of the CF Worker.
# Leave blank if you are not using CF Access.
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# ── Optional: Cloudflare Tunnel token ────────────────────────────────────────
# Only needed if you use cloudflared to expose services.
# Leave blank to skip.
TUNNEL_TOKEN=

# ── Optional: audit log row cap (default 10000) ───────────────────────────────
AUDIT_MAX_ROWS=10000

# ── Generated by bootstrap + post-bootstrap.sh — do not edit manually ────────
# These are filled in automatically after a successful bootstrap run.
# They are listed here so you can see the full expected shape of .env.
FORGE_ADAPTER_REGISTRY=
FORGE_TOKEN_LITELLM=
FORGE_TOKEN_PROXY=
FORGE_TOKEN_UI=
FORGE_TOKEN_PROBE=
FORGE_HMAC_KEY=
CF_WORKER_URL=
LITELLM_ALLOWED_KEYS=
PROXY_ALLOWED_KEYS=
PROBE_ALLOWED_KEYS=
UI_ALLOWED_KEYS=
