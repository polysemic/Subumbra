    {
      "key_id": "anthropic_policy_gold",
      "provider": "anthropic",
      "secret_ref": "ANTHROPIC_KEY",
      "adapters": ["litellm", "openwebui"],
      "unique_vault": false,
      "policy": {
        "key_id": "anthropic_policy_gold",
        "policy_id": "anthropic-policy-gold-reference",
        "protocol": "http_rest",
        "capability_class": "llm",
        "source": "env",
        "target": {
          "host": "api.anthropic.com",
          "base_path": "/v1"
        },
        "auth": {
          "scheme": "header",
          "header_name": "x-api-key"
        },
        "allow": {
          "adapters": ["litellm", "openwebui"],
          "methods": ["GET", "POST", "PUT", "PATCH", "DELETE"],
          "path_prefixes": ["/v1/messages", "/v1/models"],
          "content_types": ["application/json"],
          "max_body_bytes": 1048576
        },
        "deny": {
          "path_prefixes": ["/v1/fine-tuning"]
        },
        "intent": {
          "policy_match": "subumbra-intent-baseline-v1",
          "trust": {
            "allowed_initiators": ["litellm-proxy", "openwebui-server"],
            "allowed_content_sources": ["operator-ui", "api-request-body"]
          }
        },
        "response": {
          "deny_patterns": ["api_key", "sk-", "authorization"]
        },
        "velocity": {
          "adapter_rpm": 120,
          "key_rpm": 600,
          "breaker_failures": 3,
          "breaker_cooldown_seconds": 30
        }
      }
    }
  ]
