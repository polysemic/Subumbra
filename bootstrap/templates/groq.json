{
  "adapter_notes": "Groq OpenAI-compatible API.",
  "allow": {
    "content_types": ["application/json"],
    "max_body_bytes": 1048576,
    "methods": ["GET", "POST"],
    "path_prefixes": ["/openai/v1", "/v1"]
  },
  "auth": {
    "scheme": "bearer"
  },
  "capability_class": "llm",
  "protocol": "openai_compatible",
  "target": {
    "base_path": "/openai/v1",
    "host": "api.groq.com"
  }
}
